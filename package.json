{
  "name": "grimoire",
  "version": "1.0.0",
  "description": "A grimoire Obsidian plugin",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck -p tsconfig.build.json && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:mutate": "stryker run --incremental",
    "lint": "eslint src",
    "arch:check": "depcruise src --config .dependency-cruiser.cjs --progress",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [],
  "author": "Volodymyr Koval",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "@stryker-mutator/core": "^7.3.0",
    "@stryker-mutator/typescript-checker": "^7.3.0",
    "@stryker-mutator/vitest-runner": "^7.3.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "builtin-modules": "^3.3.0",
    "dependency-cruiser": "^16.2.1",
    "esbuild": "^0.20.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "happy-dom": "^20.9.0",
    "obsidian": "latest",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
