{
  "name": "grimoire",
  "version": "1.0.0",
  "description": "A grimoire Obsidian plugin",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mutate": "stryker run --incremental",
    "lint": "eslint src --ext .ts",
    "arch:check": "depcruise src --config .dependency-cruiser.cjs --progress",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [],
  "author": "Volodymyr Koval",
  "license": "MIT",
  "devDependencies": {
    "@stryker-mutator/core": "^7.3.0",
    "@stryker-mutator/typescript-checker": "^7.3.0",
    "@stryker-mutator/vitest-runner": "^7.3.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "builtin-modules": "^3.3.0",
    "dependency-cruiser": "^16.2.1",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "happy-dom": "^20.9.0",
    "obsidian": "latest",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
